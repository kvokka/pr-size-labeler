# GitHub App ID from the GitHub App settings page.
APP_ID=123456

# Webhook secret created in the GitHub App webhook configuration.
WEBHOOK_SECRET=replace-me

# GitHub App private key PEM downloaded from the GitHub App settings page.
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Local default is :8080. On Hugging Face Spaces use :7860.
LISTEN_ADDR=:8080

# Leave this as GitHub.com unless you run against GitHub Enterprise Server.
GITHUB_API_BASE_URL=https://api.github.com/

# Optional: set to true to include request IP/header details, installation IDs, and startup diagnostics in logs.
LOG_PRIVATE_DETAILS=false

# Optional: on startup, inspect recent failed GitHub App webhook deliveries and request redelivery.
STARTUP_FAILED_DELIVERY_RECOVERY_ENABLED=false

# Optional: Go duration string controlling how far back startup recovery looks. Default is 2h.
STARTUP_FAILED_DELIVERY_RECOVERY_LOOKBACK=2h

# Optional: when a repository is connected to the app, backfill labels for currently open PRs inside this lookback window.
CONNECT_OPEN_PRS_BACKFILL_ENABLED=false

# Optional: Go duration string, plus `y` shorthand, controlling how far back connect-time open-PR backfill looks. Default is 1y.
CONNECT_OPEN_PRS_BACKFILL_LOOKBACK=1y
